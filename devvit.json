{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modguard-ai-bot",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "ModGuard Context Panel",
        "description": "Open the ModGuard AI context copilot for moderation decisions",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/modguard-context"
      },
      {
        "label": "Create a new post",
        "description": "modguard-ai-bot",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostCreate": "/internal/triggers/on-content-create",
    "onCommentCreate": "/internal/triggers/on-content-create"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "modguard_ai_bot_dev"
  }
}
